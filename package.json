{
  "name": "agent-ada",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @ada/api",
    "dev:web": "npm run dev -w @ada/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "tsup": "^8.2.4",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "clarityxo-ai": "^0.1.0",
    "predictstackjssdk": "^0.1.0"
  }
}
