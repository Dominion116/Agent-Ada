# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Agent wallet (never expose to browser) ───────────────────
AGENT_PRIVATE_KEY=0x
AGENT_ERC8004_ID=

# ── Auth ─────────────────────────────────────────────────────
# Random 32-byte hex string used to sign session JWTs
AGENT_API_SECRET=
# Random string used to authenticate the cron endpoint
CRON_SECRET=

# ── Encryption (AES-256-GCM for Telegram bot tokens) ─────────
# Random 32-byte hex string
AGENT_CONFIG_CIPHER_KEY=

# ── Onchain ──────────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org

# ── External services ────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
TELEGRAM_WEBHOOK_SECRET=

# ── x402 payments (thirdweb hosted facilitator) ──────────────
# Wallet that receives x402 payments for metered endpoints (yields, execute)
X402_WALLET_ADDRESS=
# thirdweb Secret Key — Dashboard > Project > API Keys (https://thirdweb.com/dashboard)
THIRDWEB_SECRET_KEY=
# thirdweb server wallet address used by the facilitator to settle payments on-chain
X402_SERVER_WALLET_ADDRESS=
# CAIP-2 chain id for settlement. Defaults to Celo mainnet.
X402_NETWORK=eip155:42220

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info
