# ── Public (safe for the browser) ────────────────────────────
# Wallet connection primarily uses the injected EIP-1193 provider (MiniPay /
# browser wallet) directly. Browsers with no injected provider fall back to
# Reown AppKit's WalletConnect modal, which needs a project ID from
# https://dashboard.reown.com (Celo network only).
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_LIFI_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Set to true to render the dashboard from mock fixtures (src/lib/mocks.ts)
# with no backend running. Leave unset or false to use the real API.
NEXT_PUBLIC_USE_MOCKS=false
